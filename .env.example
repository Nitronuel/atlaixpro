# Local environment template for Atlaix development.
# Copy this file to `.env` and fill in the provider keys required for local development.

# Server-side provider keys
MORALIS_API_KEY=
ALCHEMY_API_KEY=
HELIUS_API_KEY=
GOPLUS_KEY=
GOPLUS_SECRET=

# Browser-exposed Supabase configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional backend gateway override for deployed or local API routes
VITE_API_BASE_URL=
